// Vet English training platform — modular monolith MVP.
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth & directory ---

enum UserRole {
  /// Full platform control (customer org owner / top operator).
  SUPER_ADMIN
  /// Day-to-day user and content administration; cannot override protected-system rules.
  ADMIN
  /// Learner: guided sessions and own progress.
  USER
  /// Product / program owner: metrics, templates visibility, cross-user read where granted.
  PRODUCT_OWNER
  /// Internal technical “god mode”; seeded, protected; same capability tier as SUPER_ADMIN for RBAC.
  DEVELOPER
}

// --- Sessions ---

enum SessionType {
  GUIDED_DIALOGUE
  ROLE_PLAY
  VOCABULARY_DRILL
  CASE_REVIEW
}

enum SessionStatus {
  DRAFT
  /// GPT is generating SessionQuestion rows; no answers yet.
  GENERATING_QUESTIONS
  ACTIVE
  /// Final audio uploads to storage (R2) before analysis.
  SAVING_FINAL_RESPONSES
  /// AI evaluation running after uploads and persistence.
  ANALYZING
  PAUSED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum InputMode {
  TEXT
  VOICE
  MIXED
}

// --- Progress ---

enum ReadinessLevel {
  FOUNDATION
  DEVELOPING
  PROFICIENT
  WORK_READY
}

// --- Analysis ---

enum AnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// --- AI usage & incidents ---

enum AiOperationType {
  GENERATE_QUESTIONS
  EVALUATE_SESSION
  TRANSCRIBE_AUDIO
}

enum AiUsageLogStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum TranscriptStatus {
  NONE
  PENDING
  AVAILABLE
  FAILED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  passwordHash       String
  role               UserRole  @default(USER)
  /// When false, sign-in and API acting-as-user should reject (except recovery flows).
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  /// Bootstrap / internal accounts; excluded from standard listings; immutable by normal admin flows.
  isProtectedAccount Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  profile                UserProfile?
  trainingSessions       TrainingSession[]
  progressSnapshots      ProgressSnapshot[]
  auditLogsAsActor       AuditLog[]        @relation("AuditActor")
  auditLogsAsSubject     AuditLog[]        @relation("AuditSubject")
  aiUsageLogs            AiUsageLog[]
  technicalIncidents     TechnicalIncident[]

  @@index([role, isActive])
  @@index([isActive])
  @@index([isProtectedAccount])
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredLocale String?
  professionalBio String?  @db.Text
  timezone        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Catalog row for a practice template (topic / framework). Questions are generated per session at runtime.
model SessionTemplate {
  id          String      @id @default(cuid())
  /// Stable key for idempotent seeds and imports (kebab-case).
  slug        String      @unique
  title       String
  description String?     @db.Text
  sessionType SessionType
  configJson  Json?
  published   Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  sessions TrainingSession[]

  @@index([published, sortOrder])
}

/// GPT-generated (or stub) question set persisted for one training session.
model SessionQuestion {
  id                   String          @id @default(cuid())
  sessionId            String
  session              TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ordinal              Int
  promptText           String          @db.Text
  helpText             String?         @db.Text
  expectedDurationSec  Int?
  suggestedDurationSec Int?
  maxDurationSec       Int?
  isRequired           Boolean         @default(true)
  generatedByModel     String?
  sourceTopic          String?         @db.Text
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  responses            SessionResponse[]
  technicalIncidents   TechnicalIncident[]

  @@unique([sessionId, ordinal])
  @@index([sessionId])
}

/// One learner attempt: one row per session question; final audio metadata + optional transcript (e.g. STT).
model TrainingSession {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String?
  template   SessionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  status    SessionStatus
  /// Primary input mode for answers (voice-first product).
  inputMode InputMode @default(VOICE)
  title     String?
  locale    String?
  notes     String?   @db.Text

  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  completedAt      DateTime?
  lastActivityAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Optional JSON: e.g. `{ "transcriptFallbackOrdinals": [1,2] }` for results UX.
  finalizationMetaJson Json?

  sessionQuestions  SessionQuestion[]
  responses         SessionResponse[]
  analyses          SessionAnalysis[]
  progressSnapshots ProgressSnapshot[]
  aiUsageLogs       AiUsageLog[]
  technicalIncidents TechnicalIncident[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([templateId])
  @@index([status, updatedAt])
}

model SessionResponse {
  id                String          @id @default(cuid())
  sessionId         String
  session           TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionQuestionId String
  sessionQuestion   SessionQuestion @relation(fields: [sessionQuestionId], references: [id], onDelete: Cascade)
  /// Denormalized ordinal for ordering without joins.
  ordinal           Int

  transcriptText     String?          @db.Text
  transcriptStatus   TranscriptStatus?
  transcriptProvider String?

  attemptCount Int @default(0)
  maxAttempts  Int @default(3)

  finalAudioStorageKey  String?   @db.Text
  finalAudioProvider    String?
  finalAudioMimeType    String?
  finalAudioBytes       Int?
  finalAudioDurationSec Int?
  finalAudioCodec       String?
  audioUploadedAt       DateTime?

  answeredAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sessionId, sessionQuestionId])
  @@index([sessionId])
  @@index([sessionQuestionId])
}

/// Persists AI (or rules) outputs; payloadJson holds structured rubric/scores with schemaVersion.
model SessionAnalysis {
  id        String          @id @default(cuid())
  sessionId String
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  status    AnalysisStatus @default(PENDING)
  model     String?
  summary   String?        @db.Text
  payloadJson Json?
  /// Bump when payloadJson shape changes (e.g. "2025-03-01").
  schemaVersion String?
  /// Discriminator for UI and workers: e.g. "pronunciation_v2", "holistic_feedback".
  resultKind    String?
  errorMessage  String?    @db.Text

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  aiUsageLogs AiUsageLog[]

  @@index([sessionId, createdAt])
  @@index([status])
}

/// OpenAI (or other provider) call accounting — questions generation, evaluation, future transcription.
model AiUsageLog {
  id               String           @id @default(cuid())
  operationType    AiOperationType
  userId           String?
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?
  session          TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  analysisId       String?
  analysis         SessionAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  provider         String
  model            String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostUsd Decimal? @db.Decimal(12, 6)
  currency         String?  @default("USD")

  status           AiUsageLogStatus
  requestMetaJson  Json?
  responseMetaJson Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([analysisId])
  @@index([operationType])
}

/// Operational / developer follow-up: failed final audio save, provider errors, etc.
model TechnicalIncident {
  id                String           @id @default(cuid())
  userId            String?
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId         String?
  session           TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionQuestionId String?
  sessionQuestion   SessionQuestion? @relation(fields: [sessionQuestionId], references: [id], onDelete: SetNull)

  stage        String
  provider     String?
  errorCode    String?
  errorMessage String          @db.Text
  detailsJson  Json?
  severity     IncidentSeverity

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([sessionQuestionId])
  @@index([severity, createdAt])
  @@index([stage])
}

model ProgressSnapshot {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  readiness  ReadinessLevel
  capturedAt DateTime       @default(now())
  /// Aggregates: streaks, skill scores, session counts — evolve with product.
  metricsJson Json?
  /// Optional link to the session that triggered this snapshot.
  sessionId String?
  session   TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, capturedAt])
  @@index([sessionId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actor         User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  subjectUserId String?
  subject       User?    @relation("AuditSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  action       String
  resourceType String
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([subjectUserId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}
