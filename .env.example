# Copy to `.env` / `.env.local` and fill in values. Never commit real secrets.

# --- Required (app + Prisma) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- Public site URL (Open Graph, canonical absolute links in production) ---
# Production / staging: your real HTTPS origin, no trailing slash, e.g. https://training.example.com
# Vercel: optional if unset — `VERCEL_URL` is used for metadata base.
# Local: defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Auth.js (optional) ---
# AUTH_URL="http://localhost:3000"

# --- OpenAI (optional; session evaluation) ---
# OPENAI_API_KEY=
